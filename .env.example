PORT=3000
# Optional: Redis URL for storing OTP sessions (recommended for production)
REDIS_URL=redis://localhost:6379

# Email provider (SendGrid) or SMTP URL
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=no-reply@ladak.com
# Or provide a full SMTP URL (e.g. smtp://user:pass@smtp.example.com)
SMTP_URL=

# Twilio for SMS
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# Security secrets - replace in production
OTP_SECRET=replace-me-with-strong-random-value
JWT_SECRET=replace-with-long-jwt-secret
JWT_EXPIRES=7d

# TTL for OTP in milliseconds (default 5 minutes)
OTP_TTL_MS=300000
# Maximum failed attempts before invalidating the session
OTP_ATTEMPT_LIMIT=5
# Rename to .env and fill with your credentials
PORT=3000
SENDGRID_API_KEY=your_sendgrid_api_key_here
SENDGRID_FROM_EMAIL=your_verified_sendgrid_from@example.com
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1234567890
